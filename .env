CELERY_BROKER_URL="amqp://rabbitmq_user:rabbitmq_password@localhost:5672//"
CELERY_RESULT_BACKEND="db+postgresql://celery_user:celery_password@localhost:5432/celery_results?options=-c%20search_path=celery"

OUTPUT_DIR=/tmp/mineru_output
ENABLE_VLM_PRELOAD=false
GPU_MEMORY_UTILIZATION=0.9

# Model VLM — tải từ HuggingFace về rồi trỏ vào đây
# Tên model mặc định: opendatalab/MinerU2.5-Pro-2605-1.2B
MINERU_MODEL_SOURCE=local
VLM_MODEL_DIR=/path/to/model/MinerU2.5-Pro-2605-1.2B

HOST=0.0.0.0
PORT=8000
